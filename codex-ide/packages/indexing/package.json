{
  "name": "@codex-ide/indexing",
  "version": "1.0.0",
  "description": "Codex IDE - Code indexing and embedding",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@codex-ide/core": "workspace:*",
    "chokidar": "^3.6.0",
    "better-sqlite3": "^11.1.2",
    "tree-sitter": "^0.21.1",
    "tree-sitter-typescript": "^0.21.2",
    "tree-sitter-javascript": "^0.21.4",
    "tree-sitter-python": "^0.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.12",
    "typescript": "^5.5.4",
    "vitest": "^2.0.4"
  }
}
