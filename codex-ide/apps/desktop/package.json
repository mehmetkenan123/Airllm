{
  "name": "codex-desktop",
  "version": "1.0.0",
  "description": "Codex IDE - Electron Desktop Application",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build && electron-builder",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "electron:dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "pnpm build && electron-builder"
  },
  "dependencies": {
    "@codex-ide/core": "workspace:*",
    "@codex-ide/ai-core": "workspace:*",
    "@codex-ide/ai-backends": "workspace:*",
    "@codex-ide/model-manager": "workspace:*",
    "@codex-ide/editor": "workspace:*",
    "@codex-ide/ui": "workspace:*",
    "@codex-ide/indexing": "workspace:*",
    "@codex-ide/lsp-client": "workspace:*",
    "@codex-ide/git": "workspace:*",
    "@codex-ide/terminal": "workspace:*",
    "@codex-ide/search": "workspace:*",
    "@codex-ide/extensions": "workspace:*",
    "electron": "^28.3.0",
    "better-sqlite3": "^11.1.2",
    "chokidar": "^3.6.0",
    "tree-sitter": "^0.21.1",
    "isomorphic-git": "^1.25.10",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "ripgrep": "^14.1.1",
    "ws": "^8.18.0",
    "uuid": "^10.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.11",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "electron-builder": "^24.13.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-plugin-electron": "^0.28.8",
    "vitest": "^2.0.4",
    "wait-on": "^7.2.0"
  }
}
